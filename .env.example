# =============================================================================
# Etsy Craft Listing Uploader — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# Your Etsy App Keystring (used as client_id in OAuth flows)
# Get both values from: https://www.etsy.com/developers/your-apps
ETSY_API_KEY=your_etsy_keystring_here

# Your Etsy App Shared Secret (used as x-api-key header in API calls)
ETSY_SHARED_SECRET=your_etsy_shared_secret_here

# OAuth callback URL — must match the Callback URL registered in your Etsy app
# For local development, Etsy allows http://localhost redirect URIs
ETSY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# =============================================================================
# ChatGPT Codex OAuth — Connect your ChatGPT subscription
# =============================================================================

# OpenAI Codex CLI client ID (public, embedded in the open-source Codex CLI)
# Find it at: https://github.com/openai/codex (inspect the auth module source)
# Or capture from a Codex CLI login request in your browser's network tab
OPENAI_CLIENT_ID=your_openai_codex_client_id_here

# Codex CLI whitelisted redirect URI — do NOT change this value
OPENAI_REDIRECT_URI=http://localhost:1455/auth/callback

# =============================================================================
# Cults3D API — Generate your API key at https://cults3d.com/en/api/keys
# =============================================================================
# These are for documentation only; credentials are stored via the Connect flow
# in data/cults3d-credentials.json and are NOT read from env vars.
# CULTS3D_USERNAME=your_cults3d_username
# CULTS3D_API_KEY=your_generated_api_key

# =============================================================================
# Cloud Storage (S3-compatible) — Required for Cults3D file uploads
# =============================================================================
# Recommended: Cloudflare R2 (free egress, S3-compatible)
# Works with any S3-compatible provider (AWS S3, MinIO, Backblaze B2, etc.)

STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your_storage_access_key
STORAGE_SECRET_ACCESS_KEY=your_storage_secret_key
STORAGE_BUCKET=your-bucket-name
STORAGE_PUBLIC_URL=https://pub-xxx.r2.dev
STORAGE_REGION=auto
